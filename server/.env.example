# =========================================================================
# KONFIGURASI ENV SERVER BACKEND - KOPI KITA
# =========================================================================
PORT=3000

# -------------------------------------------------------------------------
# SMTP Gmail Configuration (Untuk mengirim email OTP asli)
# -------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Masukkan alamat Gmail Anda di bawah ini:
SMTP_USER=your-email@gmail.com

# Masukkan sandi aplikasi (App Password) 16 karakter di bawah ini.
# BUKAN sandi akun Google utama Anda!
# Panduan pembuatan App Password Gmail:
# 1. Buka Akun Google Anda -> Keamanan (Security).
# 2. Pastikan Verifikasi 2 Langkah (2-Step Verification) sudah aktif.
# 3. Cari menu "Sandi Aplikasi" (App Passwords) di bagian bawah.
# 4. Pilih Aplikasi "Lainnya (Nama Kustom)", beri nama "Kopi Kita", lalu klik Buat.
# 5. Salin sandi 16 karakter tanpa spasi yang muncul, dan tempel di bawah ini.
SMTP_PASS=your-16-char-app-password
